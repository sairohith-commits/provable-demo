# Copy to .env and fill in. NEVER commit the real .env.

# Postgres (local dev uses docker compose on host port 5433)
DATABASE_URL="postgresql://provable:provable@localhost:5433/provable"

# Redis / Key Value (BullMQ). Use rediss:// for TLS-enabled managed Redis.
REDIS_URL="redis://localhost:6379"

# API
API_PORT=4000

# Web (build-time; the dashboard reads the API from here)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Web (server-side only; org API key used by the "Onboard agent" modal to
# call GET /org/key without exposing the key to the browser)
PROVABLE_API_KEY="pk_live_..."

# Live agents (apps/agents) — real Claude calls
ANTHROPIC_API_KEY="sk-ant-..."
AGENT_MODEL=claude-haiku-4-5-20251001
REVIEWER_MODEL=claude-sonnet-4-6
