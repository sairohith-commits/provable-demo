# apps/web local env for C2 (Clerk). Copy to apps/web/.env.local and fill in from
# your Clerk DEV instance (Clerk dashboard → API keys). .env.local is gitignored.
#
# Required — without these the app will not boot after C2:
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Route Clerk's hosted components/redirects at our in-app pages (Core-3 names):
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# DB — getActiveOrg()/provisionOrg() talk to the same Postgres the API uses.
# Use the local dev DB (or your Neon DEV branch). Must already have the C1
# clerkOrgId column.
DATABASE_URL=postgresql://provable:provable@localhost:5433/provable

# Transitional dashboard data key (still used until C3). Same value the API
# recognizes (the Atlas machine key, or any valid pk_live_ key for local data).
PROVABLE_API_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# API base URL the dashboard fetches from.
NEXT_PUBLIC_API_URL=http://localhost:4000

# NOTE: PROVABLE_INTERNAL_TOKEN is NOT needed on web until C3 (the api.ts swap).
