{
  "name": "provable-demo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "db:push": "pnpm --filter @provable/db db:push",
    "db:generate": "pnpm --filter @provable/db db:generate",
    "db:seed": "pnpm --filter @provable/db db:seed",
    "db:seed:structure": "pnpm --filter @provable/db db:seed:structure",
    "db:seed:structure:prod": "pnpm --filter @provable/db exec tsx src/seed-structure.ts",
    "agents:warmup": "pnpm --filter @provable/agents agents:warmup",
    "agents:live": "pnpm --filter @provable/agents agents:live",
    "agents:runaway": "pnpm --filter @provable/agents agents:runaway",
    "db:studio": "pnpm --filter @provable/db db:studio",
    "demo:fire": "pnpm --filter @provable/sdk demo:fire",
    "smoke:isolation:api": "pnpm --filter @provable/api exec tsx src/tenancy.test.ts",
    "smoke:isolation:web": "pnpm --filter @provable/web --config.verify-deps-before-run=false exec playwright test tests/c3-gate.spec.ts",
    "smoke:isolation": "pnpm run smoke:isolation:api && pnpm run smoke:isolation:web"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.6.3"
  }
}
